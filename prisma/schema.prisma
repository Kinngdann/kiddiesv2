generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Contestant {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  contestantId String    @unique
  firstName    String
  lastName     String
  gender       String
  age          String
  bio          String?
  picture      String?
  videoUrl     String?
  parent       String
  phone        String
  whatsapp     String
  disabled     Boolean   @default(false)
  stage1vote   Int       @default(1)
  stage2vote   Int       @default(0)
  stage3vote   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  voteLogs     VoteLog[]

  @@index([disabled, stage1vote])
  @@index([disabled, stage2vote])
  @@index([disabled, stage3vote])
}

model VoteLog {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  voterName     String
  amount        Int
  numberOfVotes Int
  voteMethod    VoteMethod
  contestantId  String
  keepAnonymous Boolean    @default(false)
  contestant    Contestant @relation(fields: [contestantId], references: [contestantId])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt

  @@index([contestantId, createdAt])
}

model PaystackTransaction {
  reference      String        @id @map("_id")
  contestantId   String
  amount         Int
  numberOfVotes  Int
  stage          Int
  voterName      String?
  keepAnonymous  Boolean       @default(false)
  expectedEmail  String
  status         PaymentStatus @default(pending)
  createdAt      DateTime      @default(now())
  processedAt    DateTime?
}

model Counter {
  key   String @id @map("_id")
  value Int
}

model ContestConfig {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  key          String    @unique
  votingOpen   Boolean   @default(false)
  currentStage Int       @default(1)
  stageLabel   String    @default("Stage 1")
  endDate      DateTime?
  updatedAt    DateTime  @default(now()) @updatedAt
}

enum VoteMethod {
  paystack
  bank_tx
}

enum PaymentStatus {
  pending
  processed
}

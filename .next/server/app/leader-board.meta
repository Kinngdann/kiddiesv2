{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/leader-board/layout,_N_T_/leader-board/page,_N_T_/leader-board"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
